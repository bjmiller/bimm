{
  "compilerOptions": {
    "target": "ES6",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "Node10",
    "checkJs": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
  },
  "include": [
    "src",
    "webpack.config.*ts",
    "*.config.js"
  ]
}
